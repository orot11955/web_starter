SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Development
DEV_DB_URL=jdbc:h2:mem:web_starter;MODE=MySQL;DATABASE_TO_UPPER=false
DEV_DB_USERNAME=sa
DEV_DB_PASSWORD=
DEV_DB_DRIVER=org.h2.Driver
DEV_SQL_INIT_MODE=always
DEV_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DEV_JWT_SECRET=dev-only-jwt-secret-key-change-me-please-32chars
DEV_JWT_ACCESS_TOKEN_MINUTES=60

# Production
PROD_DB_URL=jdbc:sqlserver://localhost:1433;databaseName=web_starter;encrypt=true;trustServerCertificate=false
PROD_DB_USERNAME=
PROD_DB_PASSWORD=
PROD_DB_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver
PROD_SQL_INIT_MODE=never
PROD_CORS_ALLOWED_ORIGINS=https://example.com
PROD_JWT_SECRET=
PROD_JWT_ACCESS_TOKEN_MINUTES=60
